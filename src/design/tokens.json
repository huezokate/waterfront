{
  "$name": "Victorian Broadsheet",
  "$description": "Single source of truth for design tokens. Edit here → run `npm run tokens` to regenerate CSS. The `figma` field maps each token to its Figma variable name for round-trip sync.",
  "color": {
    "paper": {
      "$type": "color",
      "$value": "#F4ECD8",
      "css": "--vb-paper",
      "figma": "paper/cream"
    },
    "paper-news": {
      "$type": "color",
      "$value": "#F3ECDD",
      "css": "--vb-paper-news",
      "figma": "paper/news"
    },
    "paper-aged": {
      "$type": "color",
      "$value": "#EDE4D3",
      "css": "--vb-paper-aged",
      "figma": "paper/aged"
    },
    "ink-ground": {
      "$type": "color",
      "$value": "#1A1A1A",
      "css": "--vb-ink-ground",
      "figma": "ground/ink"
    },
    "ink": {
      "$type": "color",
      "$value": "#1A1A1A",
      "css": "--vb-ink",
      "figma": "ink/body"
    },
    "ink-soft": {
      "$type": "color",
      "$value": "#4A4036",
      "css": "--vb-ink-soft",
      "figma": "ink/soft"
    },
    "ink-sepia": {
      "$type": "color",
      "$value": "#4A3826",
      "css": "--vb-ink-sepia",
      "figma": "ink/sepia"
    },
    "meta": {
      "$type": "color",
      "$value": "#5C5448",
      "css": "--vb-meta",
      "figma": "ink/meta"
    },
    "vermilion": {
      "$type": "color",
      "$value": "#B33A2B",
      "css": "--vb-vermilion",
      "figma": "accent/vermilion"
    },
    "oxblood": {
      "$type": "color",
      "$value": "#7A2E22",
      "css": "--vb-oxblood",
      "figma": "accent/oxblood"
    },
    "indigo": {
      "$type": "color",
      "$value": "#3B4A6B",
      "css": "--vb-indigo",
      "figma": "accent/indigo"
    },
    "gold": {
      "$type": "color",
      "$value": "#C8A04B",
      "css": "--vb-gold",
      "figma": "accent/gold"
    },
    "rule": {
      "$type": "color",
      "$value": "#1A1A1A",
      "css": "--vb-rule",
      "figma": "rule/hairline"
    },
    "rule-soft": {
      "$type": "color",
      "$value": "#8A6D4B",
      "css": "--vb-rule-soft",
      "figma": null
    }
  },
  "font": {
    "masthead": {
      "$type": "fontFamily",
      "$value": "'UnifrakturCook', 'IM Fell Double Pica', serif",
      "css": "--vb-font-masthead"
    },
    "display": {
      "$type": "fontFamily",
      "$value": "'IM Fell Double Pica', 'IM Fell English', Georgia, serif",
      "css": "--vb-font-display"
    },
    "body": {
      "$type": "fontFamily",
      "$value": "'IM Fell English', Georgia, 'Times New Roman', serif",
      "css": "--vb-font-body"
    },
    "sc": {
      "$type": "fontFamily",
      "$value": "'IM Fell English SC', 'IM Fell English', Georgia, serif",
      "css": "--vb-font-sc"
    }
  },
  "size": {
    "body": {
      "$type": "dimension",
      "$value": "17px",
      "css": "--vb-size-body"
    },
    "leading-body": {
      "$type": "number",
      "$value": "1.6",
      "css": "--vb-leading-body"
    },
    "measure": {
      "$type": "dimension",
      "$value": "42ch",
      "css": "--vb-measure"
    }
  },
  "space": {
    "gap": {
      "$type": "dimension",
      "$value": "16px",
      "css": "--vb-gap"
    },
    "gap-lg": {
      "$type": "dimension",
      "$value": "28px",
      "css": "--vb-gap-lg"
    },
    "touch": {
      "$type": "dimension",
      "$value": "48px",
      "css": "--vb-touch"
    }
  },
  "radius": {
    "base": {
      "$type": "dimension",
      "$value": "2px",
      "css": "--vb-radius"
    }
  }
}
